# Clé API Anthropic (pour générer le CV optimisé)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# Clés Stripe (mode live ou test)
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxx

# Prix en centimes (ex: 900 = 9,00€) et devise
PRICE_AMOUNT=900
PRICE_CURRENCY=eur

# URL publique de ton site une fois déployé (utilisée pour les redirections Stripe)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
